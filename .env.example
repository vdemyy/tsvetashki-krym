# ============================================
# НАСТРОЙКИ БЕЗОПАСНОСТИ (обязательно!)
# ============================================

# Секретный ключ для шифрования сессий (минимум 32 символа)
# Сгенерируйте случайную строку для production!
SESSION_SECRET=замените-на-длинную-случайную-строку-минимум-32-символа

# Пароль для входа в админ-панель (/admin)
# Используйте сложный пароль для production!
ADMIN_PASSWORD=замените-пароль-команды

# ============================================
# БАЗА ДАННЫХ
# ============================================

# SQLite (для разработки)
DATABASE_URL=sqlite:///./data/tsvetashki.db

# PostgreSQL (для Docker)
POSTGRES_PASSWORD=замените-пароль-базы-данных
POSTGRES_DB=tsvetashki
POSTGRES_USER=tsvetashki

# ============================================
# ВНЕШНИЕ API (опционально)
# ============================================

# OpenWeather API для прогноза погоды
# Получить ключ: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Telegram Bot Token
# Получить у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# ============================================
# ИНСТРУМЕНТЫ РАЗРАБОТКИ (опционально)
# ============================================

# pgAdmin для управления PostgreSQL
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# URL сайта для Telegram WebApp
# Для разработки используйте ngrok или локальный адрес
WEBSITE_URL=http://localhost:8000

# Режим отладки (только для разработки!)
DEBUG=False

