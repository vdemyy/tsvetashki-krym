SESSION_SECRET=замените-на-длинную-случайную-строку
ADMIN_PASSWORD=замените-пароль-команды
DATABASE_URL=sqlite:///./data/tsvetashki.db

# Docker Postgres (обязательно при docker compose up):
POSTGRES_PASSWORD=замените-пароль-базы-данных
# POSTGRES_DB=tsvetashki
# POSTGRES_USER=tsvetashki

# Для осадков в карточке (опционально):
# OPENWEATHER_API_KEY=

# Telegram-бот (docker compose --profile bot up bot):
# TELEGRAM_BOT_TOKEN=

# pgAdmin (docker compose --profile dev up pgadmin):
# PGADMIN_EMAIL=admin@admin.com
# PGADMIN_PASSWORD=admin

# URL основного сайта для Telegram WebApp Mini App (для разработки используйте локальный туннель, например ngrok)
# WEBSITE_URL=https://ваша-ссылка.ngrok-free.app

